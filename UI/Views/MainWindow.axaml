<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VpnClient.UI.ViewModels"
        mc:Ignorable="d"
        x:Class="VpnClient.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Amnezia Desktop"
        Width="1260"
        Height="840"
        MinWidth="1120"
        MinHeight="760">

    <Grid ColumnDefinitions="320,*" Margin="24">
        <Border Classes="sidebar" Padding="24">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                <StackPanel Spacing="10">
                    <TextBlock Text="Amnezia Desktop" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Classes="muted"
                               Text="Локальный клиент поверх конфигов Amnezia. Без генерации ключей и без панели управления."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Classes="inner-panel" Grid.Row="1" Margin="0,24,0,0" Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="Импорт сервера" />
                        <TextBlock Classes="muted"
                                   Text="Открой .vpn или .conf. Профиль сохранится локально и станет активным для подключения."
                                   TextWrapping="Wrap" />
                        <Button Classes="import-button"
                                Content="{Binding ImportButtonText}"
                                Click="OnImportConfigClick" />
                        <TextBlock Text="{Binding ImportStateText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Classes="inner-panel" Grid.Row="2" Margin="0,18,0,0" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Текущий сервер" />
                        <TextBlock Text="{Binding ProfileSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="muted"
                                   Text="Сначала импорт, потом одно действие подключения. Никакой выдачи ключей внутри клиента."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Classes="inner-panel" Grid.Row="4" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Фокус" />
                        <TextBlock Classes="muted"
                                   Text="Следующий этап: добить полную совместимость import path Amnezia и только после этого наращивать multi-profile UX."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="22,0,0,0">
            <Border Classes="panel" Padding="24">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Подключение" Classes="section-title" />
                        <TextBlock Classes="muted"
                                   Text="Клиент повторяет import/connect flow Amnezia, а не сценарии control plane."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Classes="status-pill"
                            Padding="14,8"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="#FBB26A" FontWeight="SemiBold" />
                    </Border>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,18,0,0">
                        <Border Classes="info-chip" Padding="12,7">
                            <TextBlock Text="{Binding ProfileFormat}" />
                        </Border>
                        <Border Classes="info-chip" Padding="12,7">
                            <TextBlock Text="{Binding ProfileDns}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="420,*" Margin="0,22,0,22">
                <Border Classes="panel" Padding="24" Margin="0,0,22,0">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="section-title" Text="Туннель" />
                            <TextBlock Classes="muted" Text="{Binding ConnectionHint}" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="264"
                                    Height="264"
                                    Background="Transparent"
                                    BorderBrush="#2C2D30"
                                    BorderThickness="1"
                                    CornerRadius="132" />

                            <Border Width="228"
                                    Height="228"
                                    Background="Transparent"
                                    BorderBrush="#FBB26A"
                                    BorderThickness="2"
                                    CornerRadius="114"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />

                            <Button Classes="connect-button"
                                    Width="188"
                                    Height="188"
                                    Content="{Binding PrimaryButtonText}"
                                    Command="{Binding ToggleConnectionCommand}"
                                    IsEnabled="{Binding CanToggleConnection}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Grid.Row="2" Spacing="8">
                            <TextBlock Classes="metric-title" Text="Файл профиля" />
                            <TextBlock Text="{Binding ProfileFileName}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">
                    <Border Classes="panel" Padding="24">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Classes="section-title" Text="Параметры сервера" />

                            <Grid Grid.Row="1" ColumnDefinitions="150,*" Margin="0,22,0,0">
                                <TextBlock Classes="metric-title" Text="Имя" />
                                <TextBlock Grid.Column="1" Text="{Binding ProfileTitle}" />
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="150,*" Margin="0,12,0,0">
                                <TextBlock Classes="metric-title" Text="Endpoint" />
                                <TextBlock Grid.Column="1" Text="{Binding ProfileEndpoint}" />
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="150,*" Margin="0,12,0,0">
                                <TextBlock Classes="metric-title" Text="Адрес" />
                                <TextBlock Grid.Column="1" Text="{Binding ProfileAddress}" />
                            </Grid>

                            <Grid Grid.Row="4" ColumnDefinitions="150,*" Margin="0,12,0,0">
                                <TextBlock Classes="metric-title" Text="DNS" />
                                <TextBlock Grid.Column="1" Text="{Binding ProfileDns}" />
                            </Grid>

                            <Grid Grid.Row="5" ColumnDefinitions="150,*" Margin="0,12,0,0">
                                <TextBlock Classes="metric-title" Text="Импорт" />
                                <TextBlock Grid.Column="1" Text="{Binding ImportedAt}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Classes="panel" Grid.Row="1" Padding="24" Margin="0,18,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="section-title" Text="Источник" />
                            <TextBlock Text="{Binding ProfileSourcePath}" TextWrapping="Wrap" />
                            <TextBlock Classes="muted"
                                       Text="Пока храним один локальный активный профиль. Следующий шаг — аккуратный multi-profile слой без логики выдачи."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Classes="panel" Grid.Row="2" Padding="24" Margin="0,18,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="section-title" Text="Границы клиента" />
                            <TextBlock Classes="muted"
                                       Text="Никакого добавления пользователей, управления нодами и генерации ключей. Только импорт, подключение и локальная диагностика."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Classes="panel" Grid.Row="2" Padding="24">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Classes="section-title" Text="Диагностика" />
                        <TextBlock Classes="muted" Text="Локальный журнал клиента" VerticalAlignment="Center" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,0,0,12" BorderBrush="#2C2D30" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,*">
                                            <TextBlock Classes="muted"
                                                       Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Message}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
