<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:VpnClient.Core.Models;assembly=VpnClient.Core"
        xmlns:vm="clr-namespace:VpnClient.UI.ViewModels"
        mc:Ignorable="d"
        x:Class="VpnClient.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VPN"
        Width="380"
        Height="760"
        MinWidth="340"
        MinHeight="620">

    <Border Classes="phone-shell"
            Padding="18,16,18,22">
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid ColumnDefinitions="44,*,44" ColumnSpacing="12">
                <Button Classes="icon-button"
                        Content="+"
                        IsVisible="{Binding ShowImportShortcut}"
                        Click="OnImportConfigClick" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Width="18"
                           Height="18"
                           Source="avares://VpnClient.UI/Assets/shield.png" />

                    <TextBlock Classes="app-title"
                               VerticalAlignment="Center"
                               Text="VPN" />
                </StackPanel>

                <Button Grid.Column="2"
                        Classes="icon-button alert-button"
                        Content="!"
                        IsVisible="{Binding ShowUpdateAction}"
                        IsEnabled="{Binding CanRunUpdateAction}"
                        Command="{Binding RunUpdateActionCommand}"
                        ToolTip.Tip="{Binding UpdateActionText}" />
            </Grid>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="18">
                <TextBlock Classes="muted"
                           MaxWidth="260"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding HasNoProfiles}"
                           Text="{Binding EmptyStateText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <Button Classes="ring-button"
                        HorizontalAlignment="Center"
                        BorderBrush="{Binding RingAccentBrush}"
                        Foreground="{Binding RingAccentBrush}"
                        Click="OnPrimaryActionClick">
                    <TextBlock Classes="power-glyph" Text="⏻" />
                </Button>

                <TextBlock Classes="status-value"
                           HorizontalAlignment="Center"
                           Foreground="{Binding RingAccentBrush}"
                           Text="{Binding ConnectionLabelText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="2"
                    IsVisible="{Binding HasProfiles}"
                    Padding="16"
                    Classes="glass-card">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <TextBlock Grid.Row="0"
                               Classes="card-label"
                               Text="Сервер" />

                    <ComboBox Grid.Row="1"
                              Classes="profile-combo"
                              ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ImportedServerProfile">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="2"
                               Classes="muted"
                               Text="{Binding EndpointText}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
