<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VpnClient.UI.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="#1A0F45" />
            <Setter Property="Foreground" Value="#F9F5FF" />
        </Style>

        <Style Selector="Border.phone-shell">
            <Setter Property="Background" Value="#1A0F45" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.glass-card">
            <Setter Property="Background" Value="#211251" />
            <Setter Property="BorderBrush" Value="#3A2A72" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style Selector="TextBlock.app-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.time-value">
            <Setter Property="FontSize" Value="44" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.status-value">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#BCB2E3" />
        </Style>

        <Style Selector="TextBlock.card-label">
            <Setter Property="Foreground" Value="#B2A8DB" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBlock.card-value">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.power-glyph">
            <Setter Property="FontSize" Value="56" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,-4,0,0" />
        </Style>

        <Style Selector="Button.icon-button">
            <Setter Property="Background" Value="#28175D" />
            <Setter Property="Foreground" Value="#F9F5FF" />
            <Setter Property="BorderBrush" Value="#44307C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.cta-button">
            <Setter Property="Background" Value="#1FE3D5" />
            <Setter Property="Foreground" Value="#0D1030" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.ring-button">
            <Setter Property="Background" Value="#211251" />
            <Setter Property="Foreground" Value="#F6F3FF" />
            <Setter Property="BorderBrush" Value="#61F2E5" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Width" Value="148" />
            <Setter Property="Height" Value="148" />
            <Setter Property="FontSize" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="ComboBox.profile-combo">
            <Setter Property="Background" Value="#25145A" />
            <Setter Property="Foreground" Value="#F9F5FF" />
            <Setter Property="BorderBrush" Value="#433173" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
    </Application.Styles>
</Application>
